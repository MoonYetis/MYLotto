# --- Nodo Fractal RPC (Tailscale) ---
FRACTAL_RPC_URL=http://100.64.0.1:8332
FRACTAL_RPC_USER=moonyetis_rpc
FRACTAL_RPC_PASSWORD=changeme
FRACTAL_RPC_TIMEOUT_MS=15000

# --- Postgres ---
DATABASE_URL=postgresql://myloto:myloto@localhost:5432/myloto

# --- Backend ---
PORT=3000
LOG_LEVEL=info

# --- XPUB BIP86 (OBLIGATORIO desde Ciclo 4 — derivación de direcciones de boleto) ---
# Mainnet: empieza con "xpub", nivel m/86'/0'/0'.
XPUB_BIP86=xpub6BgBgspe...

# --- Precios de boleto (Hold-to-Earn) ---
TICKET_PRICE_FB=100
TICKET_DISCOUNT_PRICE_FB=80

# --- Worker de verificación de pagos ---
PAYMENT_CHECK_INTERVAL_MS=30000
PAYMENT_MIN_CONFIRMATIONS=1

# --- Worker de cálculo de sorteos (Ciclo 5) ---
DRAW_CHECK_INTERVAL_MS=30000

# --- Wallet del nodo para verificación de pagos (multi-wallet watch-only) ---
# Vacío = wallet por defecto del nodo. "myloto_watchonly" = wallet observador
# que tiene importado el descriptor de XPUB_BIP86 (para que getreceivedbyaddress
# reconozca las direcciones de los boletos). Setup: ver docs del Ciclo 4.
FRACTAL_RPC_WALLET=myloto_watchonly

# --- UniSat BRC-20 API (para descuento Hold-to-Earn Moonyetis) ---
UNISAT_BASE_URL=https://open-api-fractal.unisat.io
UNISAT_API_KEY=your-api-key-from-developer.unisat.io
UNISAT_TIMEOUT_MS=15000
BRC20_TICKER=Moonyetis
